# ═══════════════════════════════════════════════════════════════
# Natak Annotation Tool — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────
# Your Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/service key
SUPABASE_KEY=your-supabase-anon-or-service-key

# The table name for annotations (default: annotations)
SUPABASE_TABLE=annotations

# ── Application ───────────────────────────────────────────────────
# Host and port for the Gradio server
APP_HOST=0.0.0.0
APP_PORT=7860

# Set to true to create a public Gradio share link
APP_SHARE=false

# ── Optional ─────────────────────────────────────────────────────
# Custom app title
APP_TITLE=Natak Annotation Tool
